{
  "name": "vant-vue-ledger",
  "version": "1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "preview": "vite preview --host",
    "cap:init": "npx cap init Ledger com.example.ledger",
